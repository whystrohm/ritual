# Ritual is a Claude Code skill — the primary artifact is markdown
# inside skill/ and docs/. Tell GitHub Linguist not to count the
# installation tooling, test fixtures, or example configs as the
# repo's primary language.

scripts/** linguist-detectable=false
tests/**   linguist-detectable=false
examples/** linguist-detectable=false

# Treat the skill content itself as documentation (it is — SKILL.md
# + references are prose instructions Claude reads, not code).
skill/**  linguist-documentation
docs/**   linguist-documentation

# The packaged .skill artifact is a zip, already excluded from git
# via .gitignore, but belt-and-suspenders if anyone ever commits one.
*.skill binary
